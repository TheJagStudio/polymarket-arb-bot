# ── Polymarket wallet ─────────────────────────────────────────────────────────
# Your EOA private key (from MetaMask, or reveal.magic.link/polymarket for email logins)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# 0 = self-custody EOA (MetaMask-style)
# 1 = magic-link / email-login proxy wallet
# 2 = email-login proxy wallet (newer Polymarket flow)
SIGNATURE_TYPE=0

# Required if SIGNATURE_TYPE != 0 — your Polymarket proxy address (shown under your profile)
FUNDER_ADDRESS=

# ── Polymarket endpoints ──────────────────────────────────────────────────────
CLOB_HOST=https://clob.polymarket.com
GAMMA_HOST=https://gamma-api.polymarket.com
MARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
CHAIN_ID=137

# ── Postgres (populated by `vercel env pull` once Supabase is connected) ──────
# Use the pooled connection for the bot, direct for migrations.
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=

# ── Strategy ──────────────────────────────────────────────────────────────────
# Buy YES + NO when bestAsk(YES) + bestAsk(NO) <= ARB_THRESHOLD
ARB_THRESHOLD=0.97
SHARES_PER_LEG=10
MAX_DAILY_TRADES=20
MAX_OPEN_EXPOSURE_USD=200

# ── Runtime ───────────────────────────────────────────────────────────────────
DRY_RUN=true
LOG_LEVEL=info
